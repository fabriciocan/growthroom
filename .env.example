# ── Webhook n8n ────────────────────────────────────────────────────────
# URL do webhook que recebe o payload do form e dispara o CAPI server side
# Prefixo PUBLIC_ = exposto ao browser (necessário para o FormScript)
PUBLIC_WEBHOOK_URL=https://webhook.agenciacomo.com.br/webhook/growthroom

# ── GTM ───────────────────────────────────────────────────────────────
# Já hardcoded no Layout.astro como GTM-TD9BJC9F
# Alterar aqui apenas se mudar de container
PUBLIC_GTM_ID=GTM-TD9BJC9F

