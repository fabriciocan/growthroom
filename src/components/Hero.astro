---
interface Props {
  waitlistUrl: string;
}

const { waitlistUrl } = Astro.props;
const logoUrl = "/img/logo%201.png";
---

<section class="section-shell border-b border-white/10">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 sm:px-8 sm:py-32">
    <div class="premium-chip inline-flex items-center gap-3 rounded-full px-4 py-2">
      <span class="h-2 w-2 rounded-full bg-[#C9A44A]"></span>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#C9A44A]">Growth Room Weekly Mastermind</p>
    </div>
    <div class="mt-8 max-w-xs rounded-2xl border border-[#C9A44A]/35 bg-[#0C2342]/25 p-3 shadow-2xl shadow-black/30">
      <img src={logoUrl} alt="Growth Room logo" class="w-full rounded-xl" loading="eager" />
    </div>
    <h1 class="mt-6 max-w-4xl text-4xl font-bold leading-[1.02] sm:text-6xl">
      Weekly Expert Access. Without the 6-figure price tag.
    </h1>
    <p class="mt-6 max-w-3xl text-lg text-zinc-300 sm:text-[1.35rem] sm:leading-relaxed">
      Stop wasting ad spend. Fix what’s already broken. Scale what already works.
    </p>
    <div class="mt-11 flex flex-wrap items-center gap-4">
      <a
        href={waitlistUrl}
        class="gold-ring inline-flex items-center justify-center rounded-md bg-[#C9A44A] px-8 py-3 text-base font-semibold text-black transition hover:bg-[#d9b65f]"
      >
        Join the waitlist
      </a>
      <p class="text-sm text-zinc-400">For operators already spending on paid traffic</p>
    </div>
  </div>
</section>
