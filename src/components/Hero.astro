---
interface Props {
  waitlistUrl: string;
}

const { waitlistUrl } = Astro.props;
---

<section class="border-b border-white/10">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 sm:px-8 sm:py-28">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[#C9A44A]">Growth Room</p>
    <h1 class="mt-6 max-w-4xl text-4xl font-bold leading-tight sm:text-6xl">
      Weekly Expert Access. Without the 6-figure price tag.
    </h1>
    <p class="mt-6 max-w-3xl text-lg text-zinc-300 sm:text-xl">
      Stop wasting ad spend. Fix what’s already broken. Scale what already works.
    </p>
    <div class="mt-10">
      <a
        href={waitlistUrl}
        class="inline-flex items-center justify-center rounded-md bg-[#C9A44A] px-8 py-3 text-base font-semibold text-black transition hover:bg-[#d9b65f]"
      >
        Join the waitlist
      </a>
    </div>
  </div>
</section>
