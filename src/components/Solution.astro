---
const pillars = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    title: "Weekly live sessions",
    body: "Every week — no skipping, no recordings-only. You show up, bring your account, and get direct help in real time.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    title: "Real account diagnostics",
    body: "Bring active campaigns and live data. Get direct feedback on exactly what to fix — not generic frameworks.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Applied strategy, live",
    body: "Walk away from every session with clear priorities and next actions — not homework assignments to figure out alone.",
  },
];
---

<section id="solution" class="section-shell border-b border-white/8">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 sm:px-8 sm:py-32">

    <!-- Header -->
    <div class="reveal text-center">
      <p class="section-label">The solution</p>
      <h2 class="mt-4 text-3xl font-bold sm:text-[2.75rem]">
        Growth Room is a weekly mastermind<br class="hidden sm:block" />
        built for <span class="text-[#C9A44A]">operators, not spectators.</span>
      </h2>
    </div>

    <!-- Definition box -->
    <div class="reveal mt-12 rounded-2xl border border-[#C9A44A]/25 bg-[#C9A44A]/5 px-8 py-8 text-center">
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-zinc-200 sm:text-2xl">
        A private weekly mastermind where entrepreneurs fix their real ad problems —
        <span class="text-white font-semibold">live, every single week.</span>
      </p>
      <p class="mt-4 text-sm font-semibold uppercase tracking-widest text-zinc-500">
        No courses. No templates. Just real answers.
      </p>
    </div>

    <!-- Pillars -->
    <div class="mt-10 grid gap-5 sm:grid-cols-3">
      {pillars.map(({ icon, title, body }, i) => (
        <div class={`reveal d${i + 1} glass-card rounded-2xl p-7`}>
          <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-[#C9A44A]/12 text-[#C9A44A]" set:html={icon} />
          <h3 class="mt-5 text-lg font-bold">{title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-zinc-400">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
