---
const iconCalendar = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`;
const iconChart    = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6"  y1="20" x2="6"  y2="14"/><line x1="2"  y1="20" x2="22" y2="20"/></svg>`;
const iconMessage  = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`;
const iconBolt     = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`;
const iconUsers    = `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;

const items = [
  { icon: iconCalendar, title: "Weekly live sessions",    sub: "Expert-guided, every single week" },
  { icon: iconChart,    title: "Real account reviews",    sub: "Your campaigns, live on screen" },
  { icon: iconMessage,  title: "Expert Q&A",              sub: "Direct answers to your hardest problems" },
  { icon: iconBolt,     title: "Immediate next steps",    sub: "Leave every session knowing exactly what to do" },
  { icon: iconUsers,    title: "Peer operator network",   sub: "Founders sharing what's working right now" },
];
---

<!-- DARK GOLD GRADIENT SECTION -->
<section class="section-gold-gradient border-b border-[#C9A44A]/15">
  <div class="mx-auto w-full max-w-6xl px-6 py-24 sm:px-8 sm:py-32">

    <!-- Header -->
    <div class="reveal grid sm:grid-cols-2 gap-10 items-end">
      <div>
        <p class="section-label">Value stack</p>
        <h2 class="mt-4 text-3xl font-bold leading-tight text-white sm:text-[2.75rem]">
          Access the kind of strategy companies<br class="hidden sm:block" />
          pay <span class="text-[#C9A44A]">€150K+ per year</span> for.
        </h2>
      </div>
      <p class="text-lg text-[#C9A44A]/70 leading-relaxed">
        High-level guidance at a leveraged cost — shared across a focused group
        of execution-minded founders.
      </p>
    </div>

    <!-- Full-width horizontal feature cards -->
    <div class="mt-12 flex flex-col gap-3">
      {items.map(({ icon, title, sub }, i) => (
        <div class={`reveal d${i + 1} rounded-2xl border border-[#C9A44A]/15 bg-[#C9A44A]/5 px-7 py-5 flex items-center gap-5`}>
          <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-xl border border-[#C9A44A]/25 bg-[#C9A44A]/12 text-[#C9A44A]">
            <Fragment set:html={icon} />
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-bold text-white">{title}</p>
            <p class="mt-0.5 text-sm text-[#C9A44A]/60">{sub}</p>
          </div>
          <div class="hidden sm:block shrink-0">
            <svg class="text-[#C9A44A]/30" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </div>
      ))}
    </div>

    <!-- Core offer box -->
    <div class="reveal mt-10 rounded-2xl border border-[#C9A44A]/30 bg-[#C9A44A]/8 p-8 sm:p-10 relative overflow-hidden">
      <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-[#C9A44A]/8 blur-2xl pointer-events-none"></div>
      <p class="section-label">Core offer</p>
      <p class="mt-3 text-2xl font-black text-white sm:text-3xl">
        Weekly Expert Access.<br />
        <span class="text-[#C9A44A]">Without the 6-figure price tag.</span>
      </p>
      <p class="mt-3 text-[#C9A44A]/60 text-sm max-w-lg">
        Grow together with a group of operators building real businesses on paid media — and getting real results.
      </p>
    </div>

  </div>
</section>
