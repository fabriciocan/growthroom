---
interface Props {
  waitlistUrl: string;
}
const { waitlistUrl } = Astro.props;
const logoUrl = "/img/growth%20room%201%20white.png";
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4 sm:px-8">
    <!-- Logo -->
    <a href="/" aria-label="Growth Room home">
      <img src={logoUrl} alt="Growth Room" class="h-10 w-auto" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:flex items-center gap-8">
      <a href="#solution" class="text-sm text-zinc-400 hover:text-white transition">How it works</a>
      <a href="#comparison" class="text-sm text-zinc-400 hover:text-white transition">Why Growth Room</a>
      <a
        href={waitlistUrl}
        class="btn-gold !py-2.5 !px-6 !text-sm"
      >
        Join the waitlist
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="sm:hidden p-2 text-zinc-300 hover:text-white transition"
      aria-label="Open menu"
    >
      <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
        <line x1="3" y1="6"  x2="21" y2="6"  />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" viewBox="0 0 24 24">
        <line x1="18" y1="6"  x2="6"  y2="18" />
        <line x1="6"  y1="6"  x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-[#0A0A0A]/98 backdrop-blur-xl sm:hidden"
  >
    <div class="flex flex-col gap-1 px-6 py-5">
      <a href="#solution"    class="py-3 text-sm text-zinc-300 hover:text-white border-b border-white/8 transition">How it works</a>
      <a href="#comparison"  class="py-3 text-sm text-zinc-300 hover:text-white border-b border-white/8 transition">Why Growth Room</a>
      <a href={waitlistUrl}  class="mt-3 btn-gold text-center">Join the waitlist</a>
    </div>
  </div>
</header>

<script>
  const navbar     = document.getElementById("navbar")!;
  const toggle     = document.getElementById("menu-toggle")!;
  const menu       = document.getElementById("mobile-menu")!;
  const iconOpen   = document.getElementById("icon-open")!;
  const iconClose  = document.getElementById("icon-close")!;

  window.addEventListener("scroll", () => {
    if (window.scrollY > 30) {
      navbar.classList.add("bg-[#0A0A0A]/92", "backdrop-blur-lg", "border-b", "border-white/10", "shadow-2xl");
    } else {
      navbar.classList.remove("bg-[#0A0A0A]/92", "backdrop-blur-lg", "border-b", "border-white/10", "shadow-2xl");
    }
  }, { passive: true });

  toggle.addEventListener("click", () => {
    const isOpen = !menu.classList.contains("hidden");
    menu.classList.toggle("hidden");
    iconOpen.classList.toggle("hidden", !isOpen);
    iconClose.classList.toggle("hidden", isOpen);
  });

  // Close on link click
  menu.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      iconOpen.classList.remove("hidden");
      iconClose.classList.add("hidden");
    })
  );
</script>
