---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Comparison from '../components/Comparison.astro';
import Solution from '../components/Solution.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ValueStack from '../components/ValueStack.astro';
import Benefits from '../components/Benefits.astro';
import SocialProof from '../components/SocialProof.astro';
import WaitlistCta from '../components/WaitlistCta.astro';
import Footer from '../components/Footer.astro';

const waitlistUrl = "#waitlist-form-section";
---

<Layout
  title="Growth Room | Weekly Expert Access Without the 6-Figure Price Tag"
  description="A private weekly mastermind where entrepreneurs fix real ad problems live, every week. Expert guidance at a fraction of traditional consulting costs."
>
  <Navbar waitlistUrl={waitlistUrl} />
  <Hero waitlistUrl={waitlistUrl} />
  <Problem />
  <Comparison />
  <Solution />
  <HowItWorks />
  <ValueStack />
  <Benefits />
  <SocialProof />
  <div id="waitlist">
    <WaitlistCta waitlistUrl={waitlistUrl} />
  </div>
  <Footer />
</Layout>
